   <li> <$link><$view field='title'/></$link> </li>
      <ul>
         <$list filter='[tag<currentTiddler>tag<undertype>tag<aar>]'>
            <li> <$checkbox tag=Levert/> <$link><$view field='title'/></$link> </li> 
         </$list>
      </ul>
   </$list>
</ul>
\end

