\procedure NHN-current-liste-levert(type, aar)
<ul>
   <$list filter='[tag<currentTiddler>tag<type>tag<aar>]'>
      <li> <$checkbox tag=Levert/> <$link><$view field='title'/></$link> </li> 
   </$list>
</ul>
\end


\procedure NHN-current-liste-liste-levert(type, undertype, aar)
